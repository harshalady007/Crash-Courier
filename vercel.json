{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ai-job-finder/frontend && npm ci",
  "buildCommand": "cd ai-job-finder/frontend && npm run build",
  "outputDirectory": "ai-job-finder/frontend/dist",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
