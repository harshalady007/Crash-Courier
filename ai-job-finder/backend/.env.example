# --- Core ---
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/jobfinder   # default: sqlite:///./jobfinder.db
# CORS_ORIGINS=http://localhost:5173

# --- LLM (optional; template fallback used when unset) ---
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8

# --- Key-gated connectors (all optional; free tiers available) ---
# ADZUNA_APP_ID=...            # https://developer.adzuna.com/
# ADZUNA_APP_KEY=...
# ADZUNA_COUNTRY=in            # in / us / gb / ...
# JOOBLE_API_KEY=...           # https://jooble.org/api/about
# RAPIDAPI_KEY=...             # https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch

# --- Company career pages (public board APIs, keyless) ---
# GREENHOUSE_BOARDS=stripe,cloudflare,databricks
# LEVER_BOARDS=

# --- Email digest (optional) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=you@example.com
